{
  "name": "model-picker",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@model-picker/web",
    "dev:cli": "turbo run dev --filter=@model-picker/cli",
    "refresh": "turbo run refresh --filter=@model-picker/ingest",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "turbo": "^2.8.19",
    "typescript": "^5.9.3"
  }
}
