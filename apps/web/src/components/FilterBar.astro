---
// Filter and sort controls for the model table
---

<div class="bg-white rounded-lg shadow mb-6 p-4">
  <div class="flex flex-col sm:flex-row gap-4">
    <!-- Search -->
    <div class="flex-1">
      <label for="filter-input" class="block text-sm font-medium text-gray-700 mb-1">
        Search Models
      </label>
      <input
        type="text"
        id="filter-input"
        placeholder="Filter by name, provider, or description..."
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
      />
    </div>
    
    <!-- Sort -->
    <div class="sm:w-48">
      <label for="sort-by" class="block text-sm font-medium text-gray-700 mb-1">
        Sort By
      </label>
      <select
        id="sort-by"
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-primary"
      >
        <option value="speed">Speed (tok/s) ↓</option>
        <option value="price">Price (output) ↑</option>
        <option value="context">Context Length ↓</option>
      </select>
    </div>
  </div>
  
  <!-- Quick Filters -->
  <div class="mt-4 pt-4 border-t border-gray-200">
    <span class="text-sm font-medium text-gray-700">Quick Filters:</span>
    <div class="mt-2 flex flex-wrap gap-2">
      <button 
        class="filter-btn px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded-full transition-colors"
        data-filter="coding"
      >
        Best for Coding
      </button>
      <button 
        class="filter-btn px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded-full transition-colors"
        data-filter="fast"
      >
        Fastest
      </button>
      <button 
        class="filter-btn px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded-full transition-colors"
        data-filter="cheap"
      >
        Cheapest
      </button>
      <button 
        class="filter-btn px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded-full transition-colors"
        data-filter="long-context"
      >
        Long Context
      </button>
    </div>
  </div>
</div>

<script>
  // Quick filter functionality
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      const filterInput = document.getElementById('filter-input') as HTMLInputElement;
      const sortSelect = document.getElementById('sort-by') as HTMLSelectElement;
      
      if (!filterInput || !sortSelect) return;
      
      switch (filter) {
        case 'coding':
          filterInput.value = 'claude gpt code';
          sortSelect.value = 'speed';
          break;
        case 'fast':
          filterInput.value = '';
          sortSelect.value = 'speed';
          break;
        case 'cheap':
          filterInput.value = '';
          sortSelect.value = 'price';
          break;
        case 'long-context':
          filterInput.value = '';
          sortSelect.value = 'context';
          break;
      }
      
      // Trigger events
      filterInput.dispatchEvent(new Event('input'));
      sortSelect.dispatchEvent(new Event('change'));
    });
  });
</script>
