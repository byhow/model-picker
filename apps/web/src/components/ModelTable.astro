---
// Model comparison table
// Props: models - array of consolidated model data

import type { ModelRecord } from '@model-picker/domain';

interface Props {
  models: ModelRecord[];
}

const { models } = Astro.props;

// Format numbers
const formatPrice = (price: number) => {
  if (price === 0) return 'Free';
  return `$${price.toFixed(2)}`;
};

const formatNumber = (num: number) => {
  if (num >= 1_000_000) return `${(num / 1_000_000).toFixed(1)}M`;
  if (num >= 1_000) return `${(num / 1_000).toFixed(0)}K`;
  return num.toString();
};

const getSpeedColor = (tokPerSec: number | null) => {
  if (!tokPerSec) return 'text-gray-400';
  if (tokPerSec >= 50) return 'text-green-600';
  if (tokPerSec >= 25) return 'text-yellow-600';
  return 'text-red-600';
};

const getPriceColor = (price: number) => {
  if (price === 0) return 'text-green-600';
  if (price <= 2) return 'text-green-600';
  if (price <= 10) return 'text-yellow-600';
  return 'text-red-600';
};
---

<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Model
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Speed
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Pricing (per 1M)
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Context
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Best For
          </th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            Action
          </th>
        </tr>
      </thead>
      <tbody id="model-table-body" class="bg-white divide-y divide-gray-200">
        {models.map((model) => (
          <tr class="hover:bg-gray-50 transition-colors">
            <!-- Model Name & Info -->
            <td class="px-6 py-4">
              <div class="flex items-start">
                <div>
                  <div class="text-sm font-medium text-gray-900">
                    {model.name}
                  </div>
                  <div class="text-xs text-gray-500 mt-1">
                    {model.id}
                  </div>
                  <div class="text-xs text-gray-400 mt-1 line-clamp-2 max-w-xs">
                    {model.description.slice(0, 120)}...
                  </div>
                </div>
              </div>
            </td>
            
            <!-- Speed -->
            <td class="px-6 py-4" data-sort="speed" data-value={model.speed.bestThroughput || 0}>
              {model.speed.bestThroughput ? (
                <div>
                  <div class={`text-lg font-bold ${getSpeedColor(model.speed.bestThroughput)}`}>
                    {model.speed.bestThroughput.toFixed(0)}
                    <span class="text-sm font-normal"> tok/s</span>
                  </div>
                  {model.speed.providers.length > 0 && model.speed.providers[0] && (
                    <div class="text-xs text-gray-500 mt-1">
                      via {model.speed.providers[0].name}
                    </div>
                  )}
                  {model.rank.bySpeed <= 3 && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 mt-1">
                      #{model.rank.bySpeed} fastest
                    </span>
                  )}
                </div>
              ) : (
                <span class="text-gray-400 text-sm">No data</span>
              )}
            </td>
            
            <!-- Pricing -->
            <td class="px-6 py-4" data-sort="price" data-value={model.pricing.outputPerMillion}>
              <div class="space-y-1">
                <div class="flex justify-between text-sm">
                  <span class="text-gray-500">Input:</span>
                  <span class={getPriceColor(model.pricing.inputPerMillion)}>
                    {formatPrice(model.pricing.inputPerMillion)}
                  </span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-gray-500">Output:</span>
                  <span class={`font-medium ${getPriceColor(model.pricing.outputPerMillion)}`}>
                    {formatPrice(model.pricing.outputPerMillion)}
                  </span>
                </div>
                {model.rank.byPrice <= 3 && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                    #{model.rank.byPrice} cheapest
                  </span>
                )}
              </div>
            </td>
            
            <!-- Context -->
            <td class="px-6 py-4" data-sort="context" data-value={model.contextLength}>
              <div>
                <div class="text-sm font-medium text-gray-900">
                  {formatNumber(model.contextLength)}
                </div>
                <div class="text-xs text-gray-500">
                  tokens
                </div>
                {model.rank.byContext <= 3 && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800 mt-1">
                    #{model.rank.byContext} longest
                  </span>
                )}
              </div>
            </td>
            
            <!-- Best For -->
            <td class="px-6 py-4">
              <div class="flex flex-wrap gap-1">
                {model.architecture.inputModalities.includes('image') && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    Vision
                  </span>
                )}
                {model.architecture.modality.includes('code') && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    Code
                  </span>
                )}
                {model.contextLength > 100_000 && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    Long Context
                  </span>
                )}
                {model.pricing.outputPerMillion < 1 && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    Budget
                  </span>
                )}
                {model.speed.bestThroughput && model.speed.bestThroughput > 50 && (
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    Fast
                  </span>
                )}
              </div>
            </td>
            
            <!-- Action -->
            <td class="px-6 py-4">
              <a
                href={`https://openrouter.ai/${model.id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
              >
                View on OpenRouter
                <svg class="ml-1.5 -mr-0.5 h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
