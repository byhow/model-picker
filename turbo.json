{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "apps/cli/data/**"
      ]
    },
    "dev": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    },
    "sync": {
      "cache": false
    },
    "refresh": {
      "cache": false
    },
    "fetch:models": {
      "cache": false
    },
    "build:bin": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/model-picker"
      ]
    },
    "prepare:package": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "apps/cli/data/**",
        "dist/model-picker"
      ]
    },
    "scrape:speed": {
      "cache": false
    },
    "consolidate": {
      "cache": false
    }
  }
}
