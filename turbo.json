{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "dev": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ]
    },
    "refresh": {
      "cache": false
    },
    "fetch:models": {
      "cache": false
    },
    "scrape:speed": {
      "cache": false
    },
    "consolidate": {
      "cache": false
    }
  }
}
